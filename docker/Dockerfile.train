# docker/Dockerfile.train — TrOCR ファインチューニング用コンテナ
FROM yomitori:base

COPY . /opt/ml/code/

ENV SAGEMAKER_PROGRAM="training/train_trocr.py"

CMD ["python", "-m", "training.train_trocr", \
     "--data_dir", "/opt/ml/code/data/synthetic/driver_license/", \
     "--output_dir", "/opt/ml/model", \
     "--epochs", "5", \
     "--batch_size", "8"]